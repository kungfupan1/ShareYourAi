{
  "manifest_version": 3,
  "name": "ShareYourAi",
  "version": "1.0.0",
  "description": "分布式 AI 内容生成节点调度平台",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://sora.com/*",
    "https://runwayml.com/*",
    "http://localhost:8000/*",
    "http://localhost:8001/*",
    "http://localhost:8082/*",
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:8001/*",
    "http://shareyouai.winepipeline.com:8082/*",
    "https://shareyouai.winepipeline.com/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://sora.com/*",
        "https://runwayml.com/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}